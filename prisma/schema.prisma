generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  password         String?
  image            String?
  emailVerified    DateTime?
  accounts         Account[]
  sessions         Session[]
  savedColleges    SavedCollege[]
  savedComparisons SavedComparison[]
  reviews          Review[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model College {
  id                  String            @id @default(cuid())
  name                String
  slug                String            @unique
  location            String
  city                String
  state               String
  country             String            @default("India")
  fees                Int
  rating              Float             @default(0)
  reviewCount         Int               @default(0)
  imageUrl            String?
  overview            String            @db.Text
  established         Int?
  type                CollegeType       @default(PRIVATE)
  status              CollegeStatus     @default(ACTIVE)
  accreditation       String?
  website             String?
  phone               String?
  email               String?
  nirfRank            Int?
  campusSize          String?
  totalStudents       Int?
  totalFaculty        Int?
  studentFacultyRatio String?
  hostelAvailable     Boolean           @default(true)
  logoUrl             String?
  examAccepted        ExamType[]
  cutoffRanks         CutoffRank[]
  courses             Course[]
  placements          Placement[]
  reviews             Review[]
  savedBy             SavedCollege[]
  comparisonsA        SavedComparison[] @relation("CollegeA")
  comparisonsB        SavedComparison[] @relation("CollegeB")
  comparisonsC        SavedComparison[] @relation("CollegeC")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([state])
  @@index([fees])
  @@index([rating])
  @@index([type])
  @@index([slug])
  @@index([nirfRank])
}

model CutoffRank {
  id        String   @id @default(cuid())
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  exam      ExamType
  year      Int
  category  Category @default(GENERAL)
  minRank   Int
  maxRank   Int
  course    String?
  quota     String?  // "AI" (All India), "HS" (Home State), "OS" (Other State)
  gender    String?  // "Gender-Neutral", "Female-Only"
  round     Int?     // JoSAA round number

  @@index([exam, year, category])
  @@index([collegeId])
  @@index([quota])
}

model Course {
  id        String  @id @default(cuid())
  collegeId String
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  name      String
  duration  String
  fees      Int
  seats     Int?
  degree    String

  @@index([collegeId])
}

model Placement {
  id             String  @id @default(cuid())
  collegeId      String
  college        College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  year           Int
  averagePackage Int
  highestPackage Int
  placementRate  Float
  topRecruiters  String[]

  @@index([collegeId, year])
}

model Review {
  id        String   @id @default(cuid())
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Float
  title     String
  content   String   @db.Text
  pros      String?
  cons      String?
  batch     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([collegeId, userId])
  @@index([collegeId])
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, collegeId])
}

model SavedComparison {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeAId String
  collegeBId String
  collegeCId String?
  collegeA   College  @relation("CollegeA", fields: [collegeAId], references: [id])
  collegeB   College  @relation("CollegeB", fields: [collegeBId], references: [id])
  collegeC   College? @relation("CollegeC", fields: [collegeCId], references: [id])
  createdAt  DateTime @default(now())
}

enum CollegeType {
  GOVERNMENT
  PRIVATE
  DEEMED
  AUTONOMOUS
}

enum CollegeStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ExamType {
  JEE_MAIN
  JEE_ADVANCED
  NEET
  CAT
  GATE
  XAT
  CLAT
  STATE_CET
}

enum Category {
  GENERAL
  OBC
  SC
  ST
  EWS
}
